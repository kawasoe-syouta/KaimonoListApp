# ─────────────────────────────────────────────
# Xcode
# ─────────────────────────────────────────────
# ビルド生成物
DerivedData/
build/
*.o
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ユーザー個別設定(他の人と共有しない)
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout

# Xcode 自動生成
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ─────────────────────────────────────────────
# Swift Package Manager
# ─────────────────────────────────────────────
.build/
.swiftpm/
# Package.resolved は依存バージョンの固定用なので基本コミットする(除外しない)

# ─────────────────────────────────────────────
# CocoaPods / Carthage(使う場合のみ)
# ─────────────────────────────────────────────
# Pods/
# Carthage/Build/

# ─────────────────────────────────────────────
# Firebase(秘匿情報)
# ─────────────────────────────────────────────
# 公開リポジトリでは接続情報を含む plist をコミットしない。
# クローンした人は Firebase コンソールから各自ダウンロードする(README 参照)。
GoogleService-Info.plist

# ─────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─────────────────────────────────────────────
# その他
# ─────────────────────────────────────────────
*.log
